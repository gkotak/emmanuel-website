<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>I'm New — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--paper); font-family: var(--font-sans); color: var(--ink); -webkit-font-smoothing: antialiased; }

  .welcome-hero { height: 540px; }
  .welcome-hero .em-hero__content { padding-bottom: 72px; }
  .welcome-hero h1 { font-family: var(--font-editorial); font-style: italic; font-weight: 400; font-size: 110px; line-height: 0.92; }
  .welcome-hero h1 .ro { font-style: normal; }

  .intro { padding: 100px var(--gutter) 40px; }
  .intro .inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 360px; gap: 80px; align-items: start; }
  .intro .lead-para,
  .intro .intro-body > p:first-child { font-family: var(--font-editorial); font-size: 30px; line-height: 1.32; color: var(--ink); font-style: italic; margin: 0 0 34px; letter-spacing: -0.01em; }
  .intro p { font-family: var(--font-sans); font-size: var(--fs-body); line-height: var(--lh-relaxed); color: var(--ink-soft); margin: 0 0 22px; }

  /* Flexible CMS sections */
  .sec__inner { max-width: 1320px; margin: 0 auto; }
  .sec__heading { font-family: var(--font-display); font-size: 44px; font-weight: 500; color: var(--navy); line-height: 1.02; letter-spacing: -0.015em; margin: 14px 0 0; }

  .sec--cardgrid { padding: 60px var(--gutter) 110px; }
  .sec--cardgrid .em-ornament + .sec-cards,
  .sec--cardgrid .sec__heading + .sec-cards { margin-top: 48px; }
  .sec-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 48px; }
  .sec-card { background: #fff; border: 1px solid var(--line); padding: 38px 34px 34px; display: flex; flex-direction: column; gap: 12px; transition: all var(--dur) var(--ease); }
  .sec-card:hover { border-color: var(--brown); transform: translateY(-3px); }
  .sec-card__eyebrow { font-family: var(--font-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--brown); }
  .sec-card__title { font-family: var(--font-display); font-size: 24px; font-weight: 600; color: var(--ink); margin: 0; }
  .sec-card__body { font-size: 14.5px; line-height: 1.6; color: var(--muted); margin: 0; flex-grow: 1; }

  /* Icon-list layout (two columns, heading left, ticked items) */
  .sec--iconlist { padding: 96px var(--gutter); background: var(--cream); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .sec--iconlist .sec__inner { display: grid; grid-template-columns: 380px 1fr; gap: 80px; align-items: start; }
  .sec--iconlist .sec__heading { font-size: 44px; }
  .sec-iconlist__items { display: grid; grid-template-columns: 1fr 1fr; gap: 28px 40px; }
  .sec-iconitem { display: flex; gap: 16px; align-items: flex-start; }
  .sec-iconitem__ic { width: 40px; height: 40px; flex-shrink: 0; color: var(--brown); border: 1px solid var(--line); display: flex; align-items: center; justify-content: center; background: #fff; }
  .sec-iconitem__ic svg { width: 20px; height: 20px; stroke: currentColor; stroke-width: 1.8; fill: none; stroke-linecap: round; stroke-linejoin: round; }
  .sec-iconitem__title { font-family: var(--font-display); font-size: 20px; font-weight: 600; color: var(--navy); margin: 0 0 4px; }
  .sec-iconitem__body { font-size: 14px; line-height: 1.55; color: var(--ink-soft); margin: 0; }

  @media (max-width: 768px) {
    .intro .inner { grid-template-columns: 1fr; gap: 36px; }
    .sec-cards { grid-template-columns: 1fr; gap: 16px; }
    .sec-card { padding: 24px 20px; }
    .sec--iconlist .sec__inner { grid-template-columns: 1fr; gap: 32px; }
    .sec-iconlist__items { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <!-- Hero -->
  <section class="em-hero welcome-hero">
    <div class="em-hero__bg" style="background-image:url('{{ siteImages['imnew-hero'].url or '/assets/hero-congregation.jpg' }}');background-position:center 60%"></div>
    <div class="em-hero__scrim"></div>
    <div class="em-hero__content">
      <div class="em-hero__eyebrow">I'm New</div>
      <h1>{{ sitePages['im-new'].headline }}</h1>
      <p class="em-hero__tagline">{{ sitePages['im-new'].deck }}</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="intro">
    <div class="inner">
      <div class="intro-body">
        {{ sitePages['im-new'].introBody | portableText | safe }}
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>Planning your first visit</h4>
          <p class="big" style="margin-bottom:16px">Sundays at<br/>8:00 · 9:15 · 10:30</p>
          <p>11 Lyncroft Gardens, London NW6 1JU. Step-free access at the side entrance.</p>
          <a href="service-times.html" class="em-readmore" style="margin-top:4px">See all service times →</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Flexible CMS-driven sections (service cards, pull-quote, accessibility grid) -->
  {% set sections = sitePages['im-new'].sections %}
  {% include "sections.njk" %}

  <!-- CTA -->
  <section class="em-callout">
    <div class="inner">
      <div>
        <h3>{{ sitePages['im-new'].calloutHeading }}</h3>
        {{ sitePages['im-new'].calloutBody | portableText | safe }}
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a href="contact.html" class="em-btn em-btn--tan">Contact the clergy</a>
        <a href="service-times.html" class="em-btn em-btn--ghost-light">Service times</a>
      </div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
