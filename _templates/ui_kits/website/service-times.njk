<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>Service &amp; Prayer Times — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--paper); font-family: var(--font-sans); color: var(--ink); -webkit-font-smoothing: antialiased; }
  .st-intro { padding: 96px var(--gutter) 40px; }
  .st-intro .inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 360px; gap: 80px; align-items: start; }
  .st-intro .lead-para { font-family: var(--font-editorial); font-size: 30px; line-height: 1.34; color: var(--ink); font-style: italic; margin: 0 0 30px; letter-spacing: -0.01em; }
  .st-intro p { font-family: var(--font-sans); font-size: var(--fs-body); line-height: var(--lh-relaxed); color: var(--ink-soft); margin: 0 0 22px; }
  .st-group { padding: 0 var(--gutter); }
  .st-group .inner { max-width: 1320px; margin: 0 auto; }
  .st-group + .st-group { margin-top: 64px; }
  .st-grouphead { display: flex; align-items: baseline; gap: 20px; padding-bottom: 22px; border-bottom: 1.5px solid var(--rule-ink); margin-bottom: 8px; }
  .st-grouphead h2 { font-family: var(--font-editorial); font-style: italic; font-size: 52px; font-weight: 500; color: var(--navy); margin: 0; letter-spacing: -0.015em; }
  .st-grouphead .count { font-family: var(--font-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--brown); }
  .st-tail { max-width: 1320px; margin: 0 auto; padding: 18px var(--gutter) 0; }
  .st-note { font-size: 14px; color: var(--muted); font-style: italic; font-family: var(--font-editorial); font-size: 17px; }
  .st-spacer { height: 110px; }
  .em-row { grid-template-columns: 160px 1fr 1.8fr; cursor: default; }

  @media (max-width: 768px) {
    /* Intro section: stack aside below body text */
    .st-intro { padding: 40px var(--gutter) 32px; }
    .st-intro .inner { grid-template-columns: 1fr; gap: 32px; }
    .st-intro .lead-para { font-size: 20px; margin-bottom: 18px; }
    .st-intro p { font-size: 15px; }

    /* Service group headings */
    .st-group { padding: 0 var(--gutter); }
    .st-group + .st-group { margin-top: 40px; }
    .st-grouphead { flex-direction: column; align-items: flex-start; gap: 6px; }
    .st-grouphead h2 { font-size: 36px; }

    /* Service rows: stack into 2 rows — day+time+name on top, description below */
    .em-row {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 20px 0;
    }
    .em-row__day { padding-top: 0; }
    .em-row__lead { flex-direction: row; align-items: baseline; gap: 12px; }
    .em-row__lead .t { font-size: 28px; }
    .em-row__desc { font-size: 14px; color: var(--muted); }
    .em-row__arr { display: none; }

    /* Trailing note and spacer */
    .st-note { font-size: 15px; }
    .st-spacer { height: 48px; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <section class="em-pagehead">
    <div class="inner">
      <div class="em-breadcrumb">
        <a href="/ui_kits/website/index.html">Home</a><span class="sep">/</span>
        <span>Service &amp; Prayer Times</span>
      </div>
      <h1>Service &amp; <em>Prayer</em> Times</h1>
      <p class="deck">The Eucharist and the daily office shape the rhythm of our shared life. All are welcome at every service.</p>
      <div class="meta-row">
        <div class="item"><div class="k">Sundays</div><div class="v">{% set sundayTimes = [] %}{% for st in serviceTimes %}{% if st.group === "sunday" %}{% set sundayTimes = (sundayTimes.push(st.time), sundayTimes) %}{% endif %}{% endfor %}{{ sundayTimes | join(" · ") }}</div></div>
        <div class="item"><div class="k">Weekdays</div><div class="v">{% for st in serviceTimes %}{% if st.name === "Morning Prayer" %}Morning Prayer {{ st.time }}{% endif %}{% endfor %}</div></div>
        <div class="item"><div class="k">Where</div><div class="v">11 Lyncroft Gardens, NW6</div></div>
      </div>
    </div>
  </section>

  <section class="st-intro">
    <div class="inner">
      <div>
        {% if sitePages['service-times'].introBody %}
          {{ sitePages['service-times'].introBody | portableText | safe }}
        {% else %}
          <p class="lead-para">As we gather to meet with Christ and one another, we seek to be a place where we are supported on our spiritual journeys, inspired to connect faith with the rest of our lives, and encouraged to put that faith into action.</p>
          <p>The Eucharist sits at the heart of our understanding of who we are at Emmanuel. From the very young to the very old, we seek to equip our community to discover more fully the presence of God in their lives. To help us each find our place at the table, we have a number of services of Holy Communion during the week and on Sundays.</p>
        {% endif %}
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>New to Emmanuel?</h4>
          <p>Not sure which service is right for you? We'd love to help you find your place.</p>
          <a href="/ui_kits/website/im-new.html" class="em-readmore" style="margin-top:4px">What to expect →</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="st-group">
    <div class="inner">
      <div class="st-grouphead">
        <h2>Sundays</h2>
        <span class="count">Three Eucharists</span>
      </div>
      {% for service in serviceTimes %}
        {% if service.group === "sunday" %}
        <div class="em-row">
          <div class="em-row__day">{{ service.day }}</div>
          <div class="em-row__lead">
            <div class="t">{{ service.time }}</div>
            <div class="n">{{ service.name }}</div>
          </div>
          <div class="em-row__desc">{{ service.description }}</div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>

  <section class="st-group">
    <div class="inner">
      <div class="st-grouphead">
        <h2>In the week</h2>
        <span class="count">Prayer &amp; weekday Eucharists</span>
      </div>
      {% for service in serviceTimes %}
        {% if service.group === "weekday" %}
        <div class="em-row">
          <div class="em-row__day">{{ service.day }}</div>
          <div class="em-row__lead">
            <div class="t">{{ service.time }}</div>
            <div class="n">{{ service.name }}</div>
          </div>
          <div class="em-row__desc">{{ service.description }}</div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="st-tail">
      <p class="st-note">All are welcome at every service. If you'd like to know more before visiting, do contact a member of the clergy — or simply come along.</p>
    </div>
  </section>

  <div class="st-spacer"></div>

  <section class="em-callout">
    <div class="inner">
      <div>
        <h3>Join us in <em>prayer</em>.</h3>
        <p>Whether for the first time or the thousandth, there is a place for you at the table at Emmanuel.</p>
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a href="/ui_kits/website/im-new.html" class="em-btn em-btn--tan">What to expect</a>
        <a href="/ui_kits/website/contact.html" class="em-btn em-btn--ghost-light">Contact the clergy</a>
      </div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
