<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>Room Hire — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  .em-table tbody td { padding-top: 13px; padding-bottom: 13px; }
  .rh-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 44px; }
  .rh-gallery .em-well { aspect-ratio: 4/3; }
  .em-intro { padding-bottom: 40px; }
  .em-intro + .em-section { padding-top: 56px; }

  @media (max-width: 768px) {
    .rh-gallery { grid-template-columns: 1fr; gap: 12px; }
    .em-table { font-size: 13px; }
    .em-table th, .em-table td { padding: 10px 10px; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <section class="em-pagehead em-pagehead--band">
    <div class="inner">
      <div class="em-breadcrumb"><a href="/ui_kits/website/index.html">Home</a><span class="sep">/</span><span>Room Hire</span></div>
      <h1>Room <em>Hire</em></h1>
      <p class="deck">From children's parties to community meetings, meditation sessions and concerts — Emmanuel has a range of beautiful spaces to hire.</p>
      <div class="meta-row">
        <div class="item"><div class="k">Rooms</div><div class="v">{{ roomRates | length }} spaces</div></div>
        <div class="item"><div class="k">Capacity</div><div class="v">Up to 350</div></div>
        <div class="item"><div class="k">From</div><div class="v">{% for r in roomRates %}{% if loop.first %}{{ r.rate }}{% endif %}{% endfor %}</div></div>
      </div>
    </div>
  </section>

  <section class="em-intro">
    <div class="inner">
      <div class="em-body">
        <p class="em-lead">If you would like to host a meeting, private event or a party at Emmanuel, we have a number of different rooms available.</p>
        <p>In addition to a wonderful large space for children's parties, we have smaller rooms which work well for community meetings, meditation sessions or private lessons. Whatever the occasion, we'd be glad to help you find the right space.</p>
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>Enquire about a date</h4>
          <p>Tell us what you're planning and your preferred dates, and we'll check availability and confirm a quote.</p>
          <a href="/ui_kits/website/contact.html" class="em-btn em-btn--primary" style="margin-top:4px">Enquire now</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="em-section em-section--band">
    <div class="inner">
      <div class="em-sectionhead">
        <div class="em-ornament is-leading">Our spaces</div>
        <h2>Rates for room hire</h2>
      </div>
      <table class="em-table">
        <thead>
          <tr><th>Room</th><th class="num">Rate</th><th class="num">Max capacity (seated)</th></tr>
        </thead>
        <tbody>
          {% for r in roomRates %}
          <tr{% if r.featured %} class="feature"{% endif %}>
            <td class="room">{{ r.room }}{% if r.note %}<small>{{ r.note }}</small>{% endif %}</td>
            <td class="rate num">{{ r.rate }}</td>
            <td class="cap num">{{ r.capacity }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <div class="rh-gallery">
        <div class="em-well">
          <img src="/assets/room-hire-party.jpg" alt="A children's party inflatable set up in the nave" />
        </div>
        <div class="em-well">
          <div class="em-img-placeholder"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
        </div>
        <div class="em-well">
          <div class="em-img-placeholder"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
        </div>
      </div>
    </div>
  </section>

  <section class="em-callout">
    <div class="inner">
      <div><h3>Find your <em>space</em>.</h3><p>Tell us about your event and we'll help you choose the right room and confirm availability.</p></div>
      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a href="/ui_kits/website/contact.html" class="em-btn em-btn--tan">Enquire about hire</a>
        <a href="/ui_kits/website/contact.html" class="em-btn em-btn--ghost-light">Contact the parish office</a>
      </div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
