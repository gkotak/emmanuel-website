      <p style="font-family:var(--font-editorial); font-style:italic; font-size:16px; color:var(--muted); margin:18px 0 0; text-align:center">Emmanuel Church · Lyncroft Gardens, off West End Lane, London NW6 1JU</p>
    </div>
  </section>

  <!-- Callout -->
  <section class="em-callout">
