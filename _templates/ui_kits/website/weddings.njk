<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>Weddings & Banns of Marriage — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  .em-faq summary { cursor: pointer; list-style: none; }
  .em-faq summary::-webkit-details-marker { display: none; }
  .em-faq summary .em-ornament { margin-bottom: 14px; }
  .em-faq summary h2 { font-family: var(--font-display); font-size: var(--fs-h2); font-weight: var(--fw-medium); color: var(--navy); letter-spacing: -0.015em; line-height: 1.04; margin: 0; }
  .em-faq summary h2 em { font-style: italic; color: var(--brown); }
  .em-faq summary h2::after { content: '+'; display: inline-block; margin-left: 14px; font-style: normal; color: var(--brown); transition: transform 0.2s ease; }
  .em-faq[open] summary h2::after { transform: rotate(45deg); }
  .em-faq-body { padding-top: 22px; }
  .wedding-photo-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .wedding-photo-row .em-well { height: 360px; }
  @media (max-width: 880px) { .wedding-photo-row { grid-template-columns: 1fr; } }

  @media (max-width: 768px) {
    /* Page head meta-row: stack vertically */
    .em-pagehead .meta-row { flex-direction: column; gap: 14px; }

    /* Intro: stack aside below body */
    .em-intro .inner { grid-template-columns: 1fr !important; gap: 32px; }

    /* FAQ heading size */
    .em-faq summary h2 { font-size: 26px; }

    /* Photo row: reduce height so 3 stacked images aren't overwhelming */
    .wedding-photo-row { grid-template-columns: repeat(3, 1fr) !important; gap: 8px; margin-top: 20px; }
    .wedding-photo-row .em-well { height: 110px; }

    /* Aside card: no sticky on mobile */
    .em-aside { position: static; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <section class="em-pagehead em-pagehead--band">
    <div class="inner">
      <div class="em-breadcrumb"><a href="index.html">Home</a><span class="sep">/</span><a href="baptisms.html">Life Events</a><span class="sep">/</span><span>Weddings & Banns of Marriage</span></div>
      <h1>{{ sitePages['weddings'].headline if sitePages['weddings'].headline else "Weddings & Banns of Marriage" }}</h1>
      <p class="deck">{{ sitePages['weddings'].deck if sitePages['weddings'].deck else "We love weddings — and are always delighted to pray for and accompany couples as they take this important step." }}</p>
      <div class="meta-row"><div class="item"><div class="k">Where</div><div class="v">Emmanuel or St Cuthbert's</div></div><div class="item"><div class="k">Preparation</div><div class="v">3–4 sessions</div></div><div class="item"><div class="k">First step</div><div class="v">Contact the parish office</div></div></div>
    </div>
  </section>
  <section class="em-intro">
    <div class="inner">
      <div class="em-body">
        {% if sitePages['weddings'].introBody %}
          {{ sitePages['weddings'].introBody | portableText | safe }}
        {% else %}
          <p class="em-lead">If you are engaged and considering getting married at Emmanuel or St Cuthbert's, we would love to hear from you!</p>
          <p>We love weddings and are always delighted to pray for and accompany couples as they take this important step. We warmly encourage couples to attend three or four marriage preparation sessions ahead of the wedding day; these will be arranged between the priest and the couple, and will ensure that sessions are compatible with work and other commitments.</p>
          <p>If you would like to know more about weddings in either of our churches, please contact the parish office in the first instance and a member of the clergy will be in touch.</p>
        {% endif %}
        <details class="em-faq" style="margin-top:36px">
          <summary>
            <div class="em-ornament is-leading">A common question</div>
            <h2>Can I get married at <em>Emmanuel</em>?</h2>
          </summary>
          <div class="em-faq-body">
            <p class="em-lead" style="font-style:normal;font-family:var(--font-sans);font-size:18px;color:var(--ink-soft);line-height:1.6">If you live in the parish, it is very straightforward. If you don't, we need to establish whether you have a qualifying connection — you only need <em>one</em> of the following:</p>
            <ul class="em-checklist">
              <li>You and/or your fiancé(e) are on the electoral roll of Emmanuel or St Cuthbert's.</li>
              <li>One or both of you were baptised in the parish (by a Church of England service).</li>
              <li>One or both of you have been confirmed (by a Church of England service), with the confirmation entered in a register belonging to a church in the parish.</li>
              <li>One or both of you have parents or grandparents who were married in the parish by a Church of England service.</li>
              <li>One or both of you have had your usual place of residence in the parish for at least 6 months.</li>
              <li>One or both of your parents had their usual place of residence in the parish for at least 6 months during your lifetime.</li>
              <li>One or both of you have habitually attended public worship at Church of England services in the parish for at least 6 months.</li>
              <li>One or both of your parents have habitually attended public worship at Church of England services in the parish for at least 6 months during your lifetime.</li>
            </ul>
          </div>
        </details>
        <div class="wedding-photo-row" style="margin-top:36px">
          <div class="em-well"><img src="../../assets/wedding-bw.jpg" alt="A bride and groom standing together at the altar during their wedding ceremony, surrounded by candles and flowers" /></div>
          <div class="em-well"><img src="../../assets/wedding-couple.jpg" alt="A newly married couple sharing a joyful moment in the church after their wedding" /></div>
          <div class="em-well"><img src="../../assets/wedding-aisle.webp" alt="A bride and groom walking together down the aisle at Emmanuel" /></div>
        </div>
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>Get in touch</h4>
          <p class="big">We'd love to<br/>hear from you</p>
          <p>Contact the parish office and a member of the clergy will be in touch to begin the conversation.</p>
          <a href="contact.html" class="em-btn em-btn--primary" style="margin-top:6px">Contact the parish office</a>
        </div>
      </aside>
    </div>
  </section>
  <section class="em-callout">
    <div class="inner">
      <div>
        <h3>{{ sitePages['weddings'].calloutHeading if sitePages['weddings'].calloutHeading else "Let's begin the conversation." }}</h3>
        {% if sitePages['weddings'].calloutBody %}
          {{ sitePages['weddings'].calloutBody | portableText | safe }}
        {% else %}
          <p>Tell us a little about you and your plans, and a member of the clergy will be in touch to talk through the next steps.</p>
        {% endif %}
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap"><a href="contact.html" class="em-btn em-btn--tan">Contact the parish office</a><a href="electoral-roll.html" class="em-btn em-btn--ghost-light">About the electoral roll</a></div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
