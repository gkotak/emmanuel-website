---
permalink: /ui_kits/website/music.html
---
<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>Music &amp; Choir — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  * { box-sizing: border-box; }
  body { margin: 0; background: var(--paper); font-family: var(--font-sans); color: var(--ink); -webkit-font-smoothing: antialiased; }

  .mu-intro { padding: 96px var(--gutter) 100px; }
  .mu-intro .inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 380px; gap: 80px; align-items: start; }
  .mu-intro .lead-para,
  .mu-intro .intro-body > p:first-child { font-family: var(--font-editorial); font-size: 30px; line-height: 1.34; color: var(--ink); font-style: italic; margin: 0 0 30px; letter-spacing: -0.01em; }
  .mu-intro p { font-family: var(--font-sans); font-size: var(--fs-body); line-height: var(--lh-relaxed); color: var(--ink-soft); margin: 0 0 22px; }
  .mu-intro p a { color: var(--brown); text-decoration: underline; text-underline-offset: 3px; }

  .heritage { padding: 0 var(--gutter) 110px; }
  .heritage .inner { max-width: 1320px; margin: 0 auto; }
  .heritage .em-feature .media { aspect-ratio: 5/4; }

  .people { padding: 110px var(--gutter); background: var(--cream); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .people .inner { max-width: 1320px; margin: 0 auto; }
  .people-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; margin-top: 52px; }
  .person-row { display: grid; grid-template-columns: 200px 1fr; gap: 32px; align-items: start; }
  .person-row .em-portrait { aspect-ratio: 4/5; margin: 0; }
  .person-row .role { font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--brown); }
  .person-row h3 { font-family: var(--font-display); font-size: 28px; font-weight: 600; color: var(--navy); margin: 8px 0 14px; letter-spacing: -0.01em; }
  .person-row p { font-size: 14.5px; line-height: 1.6; color: var(--ink-soft); margin: 0; }

  .childrens { padding: 110px var(--gutter); }
  .childrens .inner { max-width: 1320px; margin: 0 auto; }
  .childrens .em-feature h2 { margin-top: 14px; }
  .childrens .em-feature .media { aspect-ratio: 4/3; }
  .childrens .em-feature p a { color: var(--brown); text-decoration: underline; text-underline-offset: 3px; }

  .flag { display:block; width:fit-content; white-space: nowrap; font-size: 10.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--brown); background: var(--paper-warm); border: 1px dashed var(--brown-soft); padding: 4px 10px; margin-bottom: 22px; }

  @media (max-width: 768px) {
    .mu-intro .inner { grid-template-columns: 1fr; gap: 36px; }
    .people-grid { grid-template-columns: 1fr; gap: 36px; }
    .person-row { grid-template-columns: 1fr; gap: 20px; }
    .person-row .em-portrait { max-height: 200px; aspect-ratio: 1/1; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <!-- Page head -->
  <section class="em-pagehead">
    <div class="inner">
      <div class="em-breadcrumb">
        <a href="index.html">Home</a><span class="sep">/</span>
        <a href="#">Get Involved</a><span class="sep">/</span>
        <span>Music &amp; Choir</span>
      </div>
      <h1>{% if sitePages['music'].headline %}{{ sitePages['music'].headline }}{% else %}Music &amp; <em>Choir</em>{% endif %}</h1>
      <p class="deck">{% if sitePages['music'].deck %}{{ sitePages['music'].deck }}{% else %}Music is at the heart of worship at Emmanuel — and our choir combines choral excellence with a welcoming, inclusive spirit.{% endif %}</p>
      <div class="meta-row">
        <div class="item"><div class="k">Sings</div><div class="v">Sundays, 10:30 Eucharist</div></div>
        <div class="item"><div class="k">Rehearsals</div><div class="v">Wednesdays, 7:15–8:15pm</div></div>
        <div class="item"><div class="k">Director of Music</div><div class="v">Will Rose</div></div>
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="mu-intro">
    <div class="inner">
      <div class="intro-body">
        {{ sitePages['music'].introBody | portableText | safe }}
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>Sing with us</h4>
          <p class="big" style="margin-bottom:16px">All ages &amp; abilities welcome</p>
          <p><b style="color:var(--ink)">Rehearsals</b><br/>Wednesdays, 7:15–8:15pm</p>
          <p><b style="color:var(--ink)">Sings</b><br/>Sunday 10:30 Eucharist &amp; major festivals</p>
          <a href="mailto:w.g.rose41@gmail.com" class="em-btn em-btn--primary" style="margin-top:8px">Email Will Rose</a>
        </div>
      </aside>
    </div>
  </section>

  {% set sections = sitePages['music'].sections %}
  {% include "sections.njk" %}

  <!-- CTA -->
  <section class="em-callout">
    <div class="inner">
      <div>
        <h3>{{ sitePages['music'].calloutHeading }}</h3>
        {{ sitePages['music'].calloutBody | portableText | safe }}
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a href="mailto:w.g.rose41@gmail.com" class="em-btn em-btn--tan">Email Will Rose</a>
        <a href="service-times.html" class="em-btn em-btn--ghost-light">Service times</a>
      </div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
