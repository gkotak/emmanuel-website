<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>Baptisms & Confirmation — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <section class="em-pagehead em-pagehead--band">
    <div class="inner">
      <div class="em-breadcrumb"><a href="index.html">Home</a><span class="sep">/</span><a href="baptisms.html">Life Events</a><span class="sep">/</span><span>Baptisms & Confirmation</span></div>
      <h1>{{ sitePages['baptisms'].headline }}</h1>
      <p class="deck">{{ sitePages['baptisms'].deck }}</p>
      <div class="meta-row"><div class="item"><div class="k">Baptisms</div><div class="v">10:30, third Sunday</div></div><div class="item"><div class="k">Confirmation</div><div class="v">Once a year, with the Bishop</div></div><div class="item"><div class="k">First Communion</div><div class="v">Good Shepherd Sunday</div></div></div>
    </div>
  </section>
  <section class="em-intro">
    <div class="inner">
      <div class="em-body">
        {{ sitePages['baptisms'].introBody | portableText | safe }}
        {% for sec in sitePages['baptisms'].sections %}
          {% if sec._type == "cardGridSection" %}
            {% for card in sec.cards %}
            <div class="em-infocard"{% if loop.first %} style="margin-top:36px"{% endif %}>
              {% if card.eyebrow %}<span class="tag">{{ card.eyebrow }}</span>{% endif %}
              {% if card.title %}<h3>{{ card.title }}</h3>{% endif %}
              {% if card.body %}<p>{{ card.body }}</p>{% endif %}
            </div>
            {% endfor %}
          {% endif %}
        {% endfor %}
      </div>
      <aside class="em-aside">
        <div class="em-aside-card">
          <h4>How to begin</h4>
          <p>If you are considering having your child baptised, would like to be baptised yourself, or are interested in First Holy Communion or Confirmation, please contact the parish office in the first instance.</p>
          <p>One of the clergy will arrange to meet with you to help you prepare and go through the service with you.</p>
          <a href="contact.html" class="em-btn em-btn--primary" style="margin-top:6px">Contact the parish office</a>
        </div>
        <div class="em-well" style="aspect-ratio:3/4">
          <img src="../../assets/baptism-font.jpg" alt="A child being held at the font during a baptism" />
        </div>
      </aside>
    </div>
  </section>
  {% set sections = sitePages['baptisms'].sections %}
  {% set skipCardGrids = true %}
  {% include "sections.njk" %}

  <section class="em-callout">
    <div class="inner">
      <div>
        <h3>{{ sitePages['baptisms'].calloutHeading }}</h3>
        {{ sitePages['baptisms'].calloutBody | portableText | safe }}
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap"><a href="contact.html" class="em-btn em-btn--tan">Contact the parish office</a><a href="service-times.html" class="em-btn em-btn--ghost-light">Service times</a></div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
