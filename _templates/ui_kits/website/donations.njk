permalink: /ui_kits/website/donations.html
---
<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8" />
<title>How Can I Help? — Emmanuel Church, West Hampstead</title>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="stylesheet" href="/styles.css" />
<style>
  .dn-costs { display:grid; grid-template-columns:repeat(5,1fr); gap:0; border-top:1.5px solid var(--rule-ink); border-bottom:1px solid var(--line); }
  .dn-cost { padding:32px 28px 34px; border-right:1px solid var(--line); display:flex; flex-direction:column; gap:14px; }
  .dn-cost:last-child { border-right:none; }
  .dn-cost .ic { width:42px; height:42px; color:var(--brown); }
  .dn-cost .ic svg { width:100%; height:100%; stroke:currentColor; stroke-width:1.4; fill:none; }
  .dn-cost h4 { font-family:var(--font-display); font-size:21px; font-weight:var(--fw-semibold); color:var(--navy); margin:0; letter-spacing:-0.01em; }
  .dn-cost p { font-family:var(--font-sans); font-size:14px; line-height:1.55; color:var(--ink-soft); margin:0; }
  .dn-giftaid { display:flex; align-items:center; gap:24px; background:var(--navy); color:#fff; padding:30px 36px; margin-top:30px; }
  .dn-giftaid .fig { font-family:var(--font-display); font-size:64px; font-weight:var(--fw-medium); color:var(--tan); line-height:0.9; letter-spacing:-0.03em; }
  .dn-giftaid .txt { font-family:var(--font-sans); font-size:15.5px; line-height:1.55; color:var(--on-dark-soft); }
  .dn-giftaid .txt b { color:#fff; font-weight:var(--fw-semibold); }
  .dn-compare { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:8px; }
  .dn-compare .item { background:#fff; border:1px solid var(--line); padding:26px 26px 28px; }
  .dn-compare .item .big { font-family:var(--font-display); font-size:40px; font-weight:var(--fw-medium); color:var(--brown); line-height:1; letter-spacing:-0.02em; margin-bottom:12px; }
  .dn-compare .item p { font-family:var(--font-sans); font-size:14.5px; line-height:1.55; color:var(--ink-soft); margin:0; }
  .dn-ways { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; }
  .dn-way { display:flex; gap:16px; align-items:flex-start; padding:24px 26px; background:var(--cream); border:1px solid var(--line); }
  .dn-way .ic { width:30px; height:30px; flex-shrink:0; color:var(--brown); }
  .dn-way .ic svg { width:100%; height:100%; stroke:currentColor; stroke-width:1.5; fill:none; }
  .dn-way h4 { font-family:var(--font-display); font-size:20px; font-weight:var(--fw-semibold); color:var(--navy); margin:0 0 4px; }
  .dn-way p { font-family:var(--font-sans); font-size:13.5px; line-height:1.5; color:var(--muted); margin:0; }

  @media (max-width: 768px) {
    .dn-costs { grid-template-columns: 1fr 1fr; }
    .dn-cost { padding: 20px 16px; }
    .dn-giftaid { flex-direction: column; align-items: flex-start; gap: 16px; padding: 20px; }
    .dn-compare { grid-template-columns: 1fr; gap: 16px; }
    .dn-ways { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .dn-costs { grid-template-columns: 1fr; }
  }
</style>
<link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
<link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png" />
</head>
<body>

{% include "header.njk" %}

  <section class="em-pagehead em-pagehead--band">
    <div class="inner">
      <div class="em-breadcrumb"><a href="index.html">Home</a><span class="sep">/</span><span>Donations &amp; How You Can Help</span></div>
      <h1>{% if sitePages['donations'].headline %}{{ sitePages['donations'].headline }}{% else %}How can I <em>help?</em>{% endif %}</h1>
      <p class="deck">{{ sitePages['donations'].deck }}</p>
      <div class="meta-row">
        <div class="item"><div class="k">Monthly running cost</div><div class="v">£15,000</div></div>
        <div class="item"><div class="k">Funded by</div><div class="v">Our congregation</div></div>
        <div class="item"><div class="k">Gift Aid adds</div><div class="v">+25%</div></div>
      </div>
      <div style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap">
        <a href="https://www.parishgiving.org.uk/donors/find-your-parish/west-hampstead-emmanuel-nw6-1ju" target="_blank" rel="noopener" class="em-btn em-btn--primary">Give via the Parish Giving Scheme</a>
        <a href="https://givealittle.co/c/2SsrQulH24nbGRr8xtfwvo" target="_blank" rel="noopener" class="em-btn em-btn--ghost-light">Give via Givealittle</a>
      </div>
    </div>
  </section>

  <!-- Intro + cost breakdown -->
  <section class="em-intro em-intro--solo">
    <div class="inner">
      <div class="em-body">
        {% if sitePages['donations'].introBody %}{{ sitePages['donations'].introBody | portableText | safe }}{% else %}<p class="em-lead">While we hold fundraising events and rent out the church, one of the foundations of our finances is the tremendous support we receive from our congregation through regular donations.</p>{% endif %}
        <p>That £15,000 a month covers everything it takes to keep Emmanuel open, alive and serving the parish — from the ministry of our clergy to the upkeep of a Victorian building, and the outreach that reaches beyond our walls.</p>
      </div>
    </div>
  </section>

  <section class="em-section" style="padding-top:0;padding-bottom:0">
    <div class="inner">
      <div class="em-sectionhead" style="margin-bottom:36px">
        <div class="em-ornament is-leading">Where it goes</div>
        <h2>What your giving <em>supports</em></h2>
      </div>
      <div class="dn-costs">
        <div class="dn-cost">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 0 0-3 3c0 1.5 1 2.5 1 4H7l-1 4h12l-1-4h-3c0-1.5 1-2.5 1-4a3 3 0 0 0-3-3z"/><path d="M6 13v3a6 6 0 0 0 12 0v-3"/><path d="M9 22h6"/></svg></span>
          <h4>Ministry</h4>
          <p>Clergy pay, housing and pension — the people who lead our worship and care.</p>
        </div>
        <div class="dn-cost">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M5 21V8l7-5 7 5v13"/><path d="M9 21v-6h6v6"/></svg></span>
          <h4>Building</h4>
          <p>Maintenance, utilities and insurance for a much-loved Victorian church.</p>
        </div>
        <div class="dn-cost">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h5"/></svg></span>
          <h4>Administration</h4>
          <p>Office costs for the day-to-day operation of the parish and its activities.</p>
        </div>
        <div class="dn-cost">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M12 3v18"/><path d="M5 8l7-5 7 5"/><path d="M5 8v8a7 7 0 0 0 14 0V8"/></svg></span>
          <h4>Services</h4>
          <p>The direct costs of worship — music, liturgy, candles, vestments and more.</p>
        </div>
        <div class="dn-cost">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 1 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg></span>
          <h4>Outreach</h4>
          <p>Reaching beyond our walls — the food bank, night shelter and other care.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How to donate -->
  <section class="em-section em-section--band">
    <div class="inner">
      <div class="em-sectionhead" style="margin-bottom:36px">
        <div class="em-ornament is-leading">Three ways to give</div>
        <h2>How to <em>donate</em></h2>
      </div>
      <div class="dn-ways">
        <div class="dn-way" style="flex-direction:column;gap:20px;padding:32px 28px 36px">
          <span class="ic"><svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
          <div style="display:flex;flex-direction:column;flex:1">
            <h4>Parish Giving Scheme</h4>
            <p style="margin-bottom:16px;flex:1">Our recommended option. PGS reduces our administration, improves our budgeting, and collects Gift Aid automatically — adding 25% to every eligible gift at no extra cost to you. Supports both monthly and one-off donations.</p>
            <a href="https://www.parishgiving.org.uk/donors/find-your-parish/west-hampstead-emmanuel-nw6-1ju" target="_blank" rel="noopener" class="em-btn em-btn--primary" style="font-size:13px;padding:10px 18px;align-self:flex-start">Give via Parish Giving Scheme</a>
          </div>
        </div>
        <div class="dn-way" style="flex-direction:column;gap:20px;padding:32px 28px 36px">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 6v6l4 2"/></svg></span>
          <div style="display:flex;flex-direction:column;flex:1">
            <h4>Givealittle</h4>
            <p style="margin-bottom:16px;flex:1">Give online via Givealittle, where you can choose a specific date each month for your payment. Supports both regular monthly giving and one-off donations.</p>
            <a href="https://givealittle.co/c/2SsrQulH24nbGRr8xtfwvo" target="_blank" rel="noopener" class="em-btn em-btn--primary" style="font-size:13px;padding:10px 18px;align-self:flex-start">Give via Givealittle</a>
          </div>
        </div>
        <div class="dn-way" style="flex-direction:column;gap:20px;padding:32px 28px 36px">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 10H2"/></svg></span>
          <div style="display:flex;flex-direction:column;flex:1">
            <h4>Standing order</h4>
            <p style="margin-bottom:16px;flex:1">Set up a direct bank transfer to Emmanuel at the frequency that suits you. Email our treasurer for bank details and a Gift Aid declaration form.</p>
            <a href="mailto:treasurer@emmanuelnw6.com" class="em-btn em-btn--primary" style="font-size:13px;padding:10px 18px;align-self:flex-start">Email the treasurer</a>
          </div>
        </div>
      </div>
      <div class="dn-giftaid" style="margin-top:30px">
        <div class="fig">+25%</div>
        <div class="txt">Gift Aid adds <b>25p to every £1</b> you give, reclaimed from HMRC — if you're a UK taxpayer, just tick the box. It costs you nothing extra.</div>
      </div>
    </div>
  </section>

  <!-- How much to donate -->
  <section class="em-section">
    <div class="inner">
      <div class="em-sectionhead">
        <div class="em-ornament is-leading">A gentle guide</div>
        <h2>How much to <em>donate</em></h2>
        <p class="em-lead">This is clearly personal — but the following may help you decide what feels right for you.</p>
      </div>
      <div class="dn-compare">
        <div class="item">
          <div class="big">3%</div>
          <p>The historic guidance from the Church of England is to consider giving <strong>3% of your disposable income</strong> — that is, income after tax and household bills.</p>
        </div>
        <div class="item">
          <div class="big">☕</div>
          <p>Some find it easier to compare their giving to other everyday costs — a few <strong>coffees</strong>, or a <strong>gym membership</strong> — and give accordingly.</p>
        </div>
        <div class="item">
          <div class="big">?</div>
          <p>If you have any questions, contact <strong>Geoffrey Shaw</strong>, our Parish Giving Officer, at <a href="mailto:emmanuelchurchgiving@gmail.com" style="color:var(--brown);text-decoration:underline;text-underline-offset:3px">emmanuelchurchgiving@gmail.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Other ways to contribute -->
  <section class="em-section em-section--band" id="other-ways">
    <div class="inner">
      <div class="em-sectionhead">
        <div class="em-ornament is-leading">Beyond giving</div>
        <h2>Other ways you can <em>contribute</em></h2>
        <p class="em-lead">There are many ways to get involved and help Emmanuel — through our services, the upkeep of the building, and supporting the wider community. Here are just a few ideas.</p>
      </div>
      <div class="dn-ways">
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg></span>
          <div><h4>Reading at a service</h4><p>Share in the liturgy by reading the lessons aloud.</p></div>
        </div>
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></span>
          <div><h4>Joining the choir</h4><p>Add your voice to the music of the Sung Eucharist.</p></div>
        </div>
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <div><h4>Greeting people</h4><p>Welcome visitors and regulars as they arrive at church.</p></div>
        </div>
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M12 2a3 3 0 0 0-3 3c0 1.5 1 2.5 1 4H7l-1 4h12l-1-4h-3c0-1.5 1-2.5 1-4a3 3 0 0 0-3-3z"/><path d="M6 13v3a6 6 0 0 0 12 0v-3"/></svg></span>
          <div><h4>Sunday School</h4><p>Lead or support our children during the morning service.</p></div>
        </div>
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M12 22c4-2 8-6 8-12a8 8 0 0 0-16 0c0 6 4 10 8 12z"/><path d="M12 13c-2 0-4-1.5-4-4"/><path d="M12 13c2 0 4-1.5 4-4"/></svg></span>
          <div><h4>Gardening</h4><p>Help keep the church grounds and green looking their best.</p></div>
        </div>
        <div class="dn-way">
          <span class="ic"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a4 4 0 0 0-5.6 5.6l-6 6a2 2 0 1 0 2.8 2.8l6-6a4 4 0 0 0 5.6-5.6l-2.5 2.5-2.1-2.1z"/></svg></span>
          <div><h4>Small building works</h4><p>Lend a hand with the practical upkeep of the building.</p></div>
        </div>
      </div>
      <p style="font-family:var(--font-sans); font-size:16px; line-height:1.6; color:var(--ink-soft); margin:32px 0 0; max-width:760px">If you'd like to help us, please talk to one of the clergy or Church Wardens, or email us at <a href="mailto:info@emmanuelnw6.com" style="color:var(--brown);text-decoration:underline;text-underline-offset:3px">info@emmanuelnw6.com</a>.</p>
    </div>
  </section>

  <!-- Callout -->
  <section class="em-callout">
    <div class="inner">
      <div><h3>{{ sitePages['donations'].calloutHeading }}</h3>{{ sitePages['donations'].calloutBody | portableText | safe }}</div>
      <div style="display:flex;gap:14px;flex-wrap:wrap"><a href="https://www.parishgiving.org.uk/donors/find-your-parish/west-hampstead-emmanuel-nw6-1ju" target="_blank" rel="noopener" class="em-btn em-btn--tan">Give via PGS</a><a href="mailto:emmanuelchurchgiving@gmail.com" class="em-btn em-btn--ghost-light">Ask about giving</a></div>
    </div>
  </section>

{% include "footer.njk" %}

</body>
</html>
